APP_NAME="Lecture Exam Coach Agent"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
PORT=3000

# Required for LLM calls. Never hard-code this key in source code.
OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-4o-mini"
LLM_TEMPERATURE=0.2

# Optional: enable only when using LangSmith/LangChain tracing.
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="lecture-exam-coach-agent"

PDF_DIR="data/pdfs"
VECTOR_STORE_PATH="data/vector_store/index.json"
EMBEDDING_MODEL="text-embedding-3-small"
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=4
